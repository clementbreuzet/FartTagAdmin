{
  "expo": {
    "name": "FartTag Admin",
    "slug": "farttag-admin",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow FartTag Admin to connect to FartTag devices."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow FartTag Admin to record audio samples for PhoneMic simulation mode."
        }
      ]
    ],
    "android": {
      "package": "com.farttag.admin",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.farttag.admin",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FartTag Admin uses the microphone to record development samples in PhoneMic simulation mode."
      }
    }
  }
}
